{
    "name": "wpdev/odata-feed",
    "description": "Embeds a Power Query OData connection into PhpSpreadsheet workbooks for live Excel refresh",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": [
        "odata",
        "power-query",
        "datamashup",
        "excel",
        "xlsx",
        "phpspreadsheet",
        "live-refresh"
    ],
    "authors": [
        {
            "name": "WPDev",
            "homepage": "https://github.com/wpdev"
        }
    ],
    "require": {
        "php": ">=7.4",
        "phpoffice/phpspreadsheet": "^1.29",
        "wpdev/phpspreadsheet-odata": "^1.0",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.5|^11.0",
        "phpstan/phpstan": "^1.10|^2.2",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "WPDev\\ODataFeed\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPDev\\ODataFeed\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "lint": "phpcs --standard=phpcs.xml",
        "lint:fix": "phpcbf --standard=phpcs.xml"
    },
    "config": {
        "sort-packages": true,
        "platform-check": false
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../phpspreadsheet-odata",
            "options": {
                "symlink": true
            }
        }
    ]
}